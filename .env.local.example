OPENAI_API_KEY=your_actual_key_here
OPENAI_MODEL=gpt-5-mini
OPENAI_FAST_MODEL=gpt-5-mini
OPENAI_DEEP_MODEL=gpt-5-mini
OPENAI_WEB_SEARCH=false

# DigitalOcean Postgres (riple database on your cluster)
# Replace HOST with the hostname from DO → Databases → carflip-db → Connection details
DATABASE_URL=postgresql://riple_user:YOUR_PASSWORD@HOST:25060/riple?sslmode=require

# Daily usage email (Resend)
REPORT_EMAIL=you@example.com
REPORT_FROM_EMAIL=Riple Reports <onboarding@resend.dev>
REPORT_TZ=America/Chicago
RESEND_API_KEY=re_xxxxxxxx
CRON_SECRET=generate-a-long-random-string
